{
  "expo": {
    "name": "UniRide",
    "slug": "uniride",
    "scheme": "uniride",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D2D2D"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.wisam99sr.uniride",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C2703E"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "28fa1803-2b1d-4c78-b4af-9b0fd8cce561"
      }
    },
    "owner": "wisam99sr",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/28fa1803-2b1d-4c78-b4af-9b0fd8cce561"
    },
    "plugins": [
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "يحتاج التطبيق إلى موقعك لعرض الخريطة وتتبع الرحلة.",
          "locationAlwaysAndWhenInUsePermission": "يحتاج التطبيق إلى موقعك لتتبع الرحلة حتى عند تصغير الشاشة."
        }
      ]
    ]
  }
}
